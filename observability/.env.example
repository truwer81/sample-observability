# Copy this file to .env for local runs. Never commit the real .env file.

SMTP_SMARTHOST=smtp.example.com:587
SMTP_FROM=alerts@example.com
SMTP_USERNAME=alerts@example.com
SMTP_TO=alerts@example.com

# Use a real local file for real SMTP credentials, for example:
# SMTP_PASSWORD_FILE=./secrets/smtp_password
# The default example secret lets the stack boot for config checks, but email delivery will fail.
SMTP_PASSWORD_FILE=./secrets/smtp_password.example

GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change-this-local-password
